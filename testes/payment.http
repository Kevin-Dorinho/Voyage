### ========================================
### VOYAGE — PAYMENT
### Token capturado automaticamente do user.http
### Execute user.http primeiro (loginOwner)
### ========================================

@base = https://voyagegabi.onrender.com
@ownerToken = {{loginOwner.response.body.token}}
@paymentId = {{createPayment.response.body.id}}

### Criando um pagamento
# @name createPayment
POST {{base}}/payment HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

{
    "toDate":      "2026-02-26T00:00:00Z",
    "dueDate":     "2026-02-28T00:00:00Z",
    "paymentForm": "PIX",
    "advertising": "Melhor Churrascaria",
    "key":         "169999999",
    "type":        "phone"
}

### Listar todos os pagamentos
GET {{base}}/payment HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

### Listar um único pagamento
GET {{base}}/payment/3 HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

### Filtro por companyId
GET {{base}}/payment?companyId=1 HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

### Filtro por data de início
GET {{base}}/payment?to_date=2026-02-26T00:00:00Z HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

### Filtro por data de vencimento
GET {{base}}/payment?due_date=2026-02-28T00:00:00Z HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

### Filtro por forma de pagamento
GET {{base}}/payment?paymentForm=PIX HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

### Filtro por anúncio
GET {{base}}/payment?advertising=Melhor%20Churrascaria HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

### Filtro por tipo
GET {{base}}/payment?type=phone HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

### Editar pagamento
PUT {{base}}/payment/3 HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

{
    "toDate":      "2026-02-26T00:00:00Z",
    "dueDate":     "2026-02-28T00:00:00Z",
    "paymentForm": "PIX",
    "advertising": "Melhor Churrascaria",
    "key":         "169999999",
    "type":        "phone"
}

### Deletar pagamento
DELETE {{base}}/payment/1 HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json
