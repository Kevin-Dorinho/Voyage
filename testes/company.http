### ========================================
### VOYAGE — COMPANY
### Token capturado automaticamente do user.http
### Execute user.http primeiro (loginOwner)
### ========================================

@base = https://voyagegabi.onrender.com
@ownerToken = {{loginOwner.response.body.token}}
@companyId = {{createCompany.response.body.id}}

### Criando uma Company
# @name createCompany
POST {{base}}/company HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

{
    "name":     "teste",
    "category": "Lanchonete",
    "cnpj":     "26.936.588/0001-83",
    "evaluate": 4.6,
    "places":   "Vila Prado"
}

### Listar todas as companies (autenticado)
GET {{base}}/company HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

### Listar todas as companies sem estar logado
GET {{base}}/company HTTP/1.1
content-type: application/json

### Listar uma única company
GET {{base}}/company/3 HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

### Filtro por nome
GET {{base}}/company?name=que HTTP/1.1
content-type: application/json

### Filtro por endereço
GET {{base}}/company?places=Ave HTTP/1.1
content-type: application/json

### Filtro por categoria
GET {{base}}/company?category=chur HTTP/1.1
content-type: application/json

### Editar company
PUT {{base}}/company/1 HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

{
    "name":     "Tabajara Grill",
    "category": "Lanchonete",
    "cnpj":     "61.851.929/0001-00",
    "evaluate": 0,
    "places":   "Avenida São Carlos, Centro"
}

### Editar outra company
PUT {{base}}/company/2 HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json

{
    "name":     "Casa do Pão de Queijo",
    "category": "Lanchonete",
    "cnpj":     "61.851.929/0001-00",
    "evaluate": 0,
    "places":   "Avenida São Carlos, Centro"
}

### Deletar company
DELETE {{base}}/company/4 HTTP/1.1
Authorization: Bearer {{ownerToken}}
content-type: application/json
